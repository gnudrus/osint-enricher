# Copy this file to config/rules.yaml and adapt thresholds as needed.
rules:
  - name: "Twitter volume spike"
    type: volume_spike
    source: twitter
    keyword: emergency
    window_seconds: 300
    threshold: 30
    cooldown_seconds: 600

  - name: "Reddit post surge"
    type: volume_spike
    source: reddit
    window_seconds: 600
    threshold: 50
    cooldown_seconds: 300
