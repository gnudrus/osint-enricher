# Example alert rules for OSINT-Enricher
# Each rule is evaluated against the enriched events stream.

rules:
  - name: "Twitter volume spike"
    description: "Trigger when >30 tweets with keyword appear in 5 minutes within a bounding box"
    condition: |
      count(source == "twitter" and keyword in text, window="5m") > 30
      and bbox(lat, lon) within [35.0, -5.0, 45.0, 10.0]  # example: Italy area
    actions:
      - type: email
        to: analyst@example.com
        subject: "[ALERT] Twitter volume spike"
        body: |
          Detected a spike in tweets matching "{{ keyword }}" in the last 5 minutes.
          Count: {{ count }}
          Region: {{ bbox }}
    cooldown: 10m  # wait before re-triggering same rule

  - name: "Reddit post surge"
    description: "Alert when new posts in a subreddit exceed threshold"
    condition: |
      count(source == "reddit" and subreddit == "worldnews", window="10m") > 50
    actions:
      - type: webhook
        url: https://hooks.slack.com/services/XXXX/XXXX/XXXX
        payload: |
          {
            "text": "*Reddit surge*: {{ count }} new posts in r/{{ subreddit }} in the last 10 minutes"
          }
    cooldown: 5m
