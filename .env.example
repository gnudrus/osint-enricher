# Environment variables for OSINT-Enricher
# Copy this file to .env and fill in your credentials.

# Twitter Academic Research API bearer token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API credentials (script app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=osint-enricher by /u/your_reddit_username

# Optional: OpenWeatherMap API key (if using weather enrichments)
OPENWEATHER_API_KEY=your_openweather_key

# Optional OpenAQ API key and public RSS feeds
OPENAQ_API_KEY=your_openaq_key
RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml
TWITTER_QUERY=-is:retweet
REDDIT_SUBREDDIT=all

# Optional: Mailtrap SMTP for testing email alerts
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=alerts@osint-enricher.local

# MinIO (local S3) credentials for object storage (used by docker compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=osint-data

# Redis connection (used as cache)
REDIS_HOST=localhost
REDIS_PORT=6379
